<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.exam.mapper.ExamMapper">
    <insert id="addExam">
        INSERT INTO exam (exam_name, duration) VALUES (#{examName}, #{duration})
    </insert>
    <select id="getAllExams" resultType="com.example.exam.entity.Exam">
        SELECT * FROM exam
    </select>
    <select id="getExamById" resultType="com.example.exam.entity.Exam">
        SELECT * FROM exam WHERE exam_id = #{examId}
    </select>
    <update id="updateExam">
        UPDATE exam SET exam_name = #{examName}, duration = #{duration} WHERE exam_id = #{examId}
    </update>
    <delete id="deleteExam">
        DELETE FROM exam WHERE exam_id = #{examId}
    </delete>
</mapper>