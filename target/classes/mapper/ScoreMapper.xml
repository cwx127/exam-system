<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.exam.mapper.ScoreMapper">
    <insert id="addScore">
        INSERT INTO score (user_id, exam_id, score) VALUES (#{userId}, #{examId}, #{score})
    </insert>
    <select id="getScoresByUserId" resultType="com.example.exam.entity.Score">
        SELECT * FROM score WHERE user_id = #{userId}
    </select>
    <select id="getScoreByUserIdAndExamId" resultType="com.example.exam.entity.Score">
        SELECT * FROM score WHERE user_id = #{userId} AND exam_id = #{examId}
    </select>
    <select id="getAllScores" resultType="com.example.exam.entity.Score">
        SELECT * FROM score
    </select>
    <update id="updateScore">
        UPDATE score SET score = #{score} WHERE score_id = #{scoreId}
    </update>
</mapper>